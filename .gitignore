#  Python auto-generated files (not useful to share)
__pycache__/
*.pyc

# Jupyter’s autosave backups (can clutter the repo)
.ipynb_checkpoints/

# Created by DBT when it runs (can get large + confusing)
target/
dbt_packages/

# Stores environment variables (sometimes contains secrets)
.env
.venv/
venv/

# OS junk
.DS_Store
Thumbs.db

# ignore generated DBT/runtime artifacts:
dbt_projects/**/target/
dbt_projects/**/logs/
dbt_projects/**/*.duckdb
dbt_projects/**/.user.yml
